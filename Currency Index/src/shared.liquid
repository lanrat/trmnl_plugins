{% assign chart_id = "chart-" | append_random %}
{% assign stats_id = "stats-" | append_random %}
{% assign chart_title_id = "chart-title-" | append_random %}
{% assign period_label_id = "period-label-" | append_random %}
{% assign error_id = "error-" | append_random %}

<style>
  .view--half_horizontal .stats-row,
  .view--half_vertical .stats-row,
  .view--quadrant .stats-row {
    display: none;
  }
  .stat-trend {
    display: inline-block;
    width: 40px;
    height: 16px;
    vertical-align: middle;
    margin-left: 4px;
  }
  .stat-strongest {
    border: 2px solid #000;
    padding: 2px 4px;
  }
  .stat-weakest {
    border: 2px dashed #000;
    padding: 2px 4px;
  }
</style>

<div class="layout layout--col gap--space-between">
  <div class="stats-row">
    <div class="grid">
      <div class="row">
        <div id="{{ stats_id }}" class="grid grid--cols-6">
        </div>
      </div>
    </div>
  </div>

  <script src="https://trmnl.com/js/highcharts/12.3.0/highcharts.js"></script>

  <div class="w--full grow mt--4" style="position: relative;">
    <div id="{{ error_id }}" style="display:none; position:absolute; top:0; bottom:0; left:0; right:0; align-items:center; justify-content:center; font-size:1.4rem; color:#555;"></div>
    <div id="{{ chart_id }}" style="position: absolute; top: 0; bottom: 0; left: 0; right: 0;"></div>
  </div>
</div>

<div class="title_bar">
  <span class="title" id="{{ chart_title_id }}">Currency Index</span>
  <span class="instance" id="{{ period_label_id }}"></span>
</div>

<script type="text/javascript">
  (function() {
    // Read settings
    const baseCurrency = "{{ trmnl.plugin_settings.custom_fields_values.base_currency | default: 'USD' }}";
    const currencyList = "{{ trmnl.plugin_settings.custom_fields_values.currencies | default: 'EUR,GBP,JPY,CAD,AUD,CNY' }}";
    const periodDays = parseInt("{{ trmnl.plugin_settings.custom_fields_values.period | default: '30' }}") || 30;

    // Parse currencies (limit to 6)
    const symbols = currencyList.split(',').map(function(s) { return s.trim().toUpperCase(); }).filter(Boolean).slice(0, 6);

    // Compute date range
    var endDate = new Date();
    var startDate = new Date();
    startDate.setDate(endDate.getDate() - periodDays);
    function fmt(d) { return d.toISOString().slice(0, 10); }

    // Update title and period label
    document.getElementById('{{ chart_title_id }}').textContent = 'Currency Index (' + baseCurrency + ')';
    var periodLabels = { 7: '7 days', 30: '30 days', 90: '90 days', 180: '6 months', 365: '1 year' };
    document.getElementById('{{ period_label_id }}').textContent = periodLabels[periodDays] || periodDays + ' days';

    // Fetch data from Frankfurter API
    var url = 'https://api.frankfurter.dev/v1/' + fmt(startDate) + '..' + fmt(endDate) + '?base=' + baseCurrency + '&symbols=' + symbols.join(',');

    fetch(url)
      .then(function(r) { return r.json(); })
      .then(function(data) {
        if (!data.rates || Object.keys(data.rates).length === 0) {
          showError('No currency data available');
          return;
        }
        renderAll(data);
      })
      .catch(function(err) {
        showError('Unable to fetch currency data');
      });

    function showError(msg) {
      var el = document.getElementById('{{ error_id }}');
      el.textContent = msg;
      el.style.display = 'flex';
      document.getElementById('{{ chart_id }}').style.display = 'none';
    }

    function renderAll(data) {
      var dates = Object.keys(data.rates).sort();
      var firstDate = dates[0];
      var lastDate = dates[dates.length - 1];
      var baseRates = data.rates[firstDate];
      var latestRates = data.rates[lastDate];

      // Filter to symbols that actually have data
      var validSymbols = symbols.filter(function(sym) {
        return baseRates[sym] !== undefined && latestRates[sym] !== undefined;
      });

      // Compute % change per symbol and find strongest/weakest
      var pctChanges = {};
      var strongestSym = null, weakestSym = null;
      var strongestPct = -Infinity, weakestPct = Infinity;
      validSymbols.forEach(function(sym) {
        var pct = ((latestRates[sym] - baseRates[sym]) / baseRates[sym]) * 100;
        pctChanges[sym] = pct;
        if (pct > strongestPct) { strongestPct = pct; strongestSym = sym; }
        if (pct < weakestPct) { weakestPct = pct; weakestSym = sym; }
      });

      // Build mini sparkline SVG for each currency
      function buildSparkline(sym) {
        var points = [];
        dates.forEach(function(dateStr) {
          if (data.rates[dateStr] && data.rates[dateStr][sym] !== undefined) {
            points.push(data.rates[dateStr][sym]);
          }
        });
        if (points.length < 2) return '';
        var min = Math.min.apply(null, points);
        var max = Math.max.apply(null, points);
        var range = max - min || 1;
        var w = 40, h = 16;
        var coords = points.map(function(v, i) {
          var x = (i / (points.length - 1)) * w;
          var y = h - ((v - min) / range) * h;
          return x.toFixed(1) + ',' + y.toFixed(1);
        }).join(' ');
        return '<svg class="stat-trend" viewBox="0 0 ' + w + ' ' + h + '" preserveAspectRatio="none">' +
          '<polyline points="' + coords + '" fill="none" stroke="#000" stroke-width="1.5"/>' +
          '</svg>';
      }

      // Update stat boxes with latest rates, sparklines, and strongest/weakest
      var statsEl = document.getElementById('{{ stats_id }}');
      var colClass = validSymbols.length <= 4 ? 'grid--cols-' + validSymbols.length : 'grid--cols-' + Math.min(validSymbols.length, 6);
      statsEl.className = 'grid ' + colClass;

      validSymbols.forEach(function(sym) {
        var rate = latestRates[sym];
        var pct = pctChanges[sym];
        var pctStr = (pct >= 0 ? '+' : '') + pct.toFixed(2) + '%';
        var precision = rate >= 100 ? 1 : (rate >= 10 ? 2 : 4);
        var sparkline = buildSparkline(sym);

        var highlightClass = '';
        var highlightLabel = '';
        if (sym === strongestSym && validSymbols.length > 1) {
          highlightClass = ' stat-strongest';
          highlightLabel = ' &#9650;';
        } else if (sym === weakestSym && validSymbols.length > 1) {
          highlightClass = ' stat-weakest';
          highlightLabel = ' &#9660;';
        }

        var item = document.createElement('div');
        item.className = 'item col--span-1' + highlightClass;
        item.innerHTML = '<div class="meta"></div>' +
          '<div class="content">' +
            '<span class="value value--xsmall value--tnums" data-value-type="number">' + rate.toFixed(precision) + '</span>' +
            sparkline +
            '<span class="label">' + sym + highlightLabel + ' <span style="font-size:0.85em;">' + pctStr + '</span></span>' +
          '</div>';
        statsEl.appendChild(item);
      });

      // Normalize to % change from period start
      var lineStyles = [
        { lineWidth: 4, dashStyle: 'Solid' },
        { lineWidth: 3, dashStyle: 'ShortDash' },
        { lineWidth: 3, dashStyle: 'ShortDot' },
        { lineWidth: 2, dashStyle: 'DashDot' },
        { lineWidth: 2, dashStyle: 'LongDash' },
        { lineWidth: 2, dashStyle: 'Dot' }
      ];

      var series = validSymbols.map(function(sym, i) {
        var seriesData = [];
        var base = baseRates[sym];
        dates.forEach(function(dateStr) {
          if (data.rates[dateStr] && data.rates[dateStr][sym] !== undefined) {
            var timestamp = new Date(dateStr + 'T00:00:00Z').getTime();
            var pctChange = ((data.rates[dateStr][sym] - base) / base) * 100;
            seriesData.push([timestamp, pctChange]);
          }
        });
        var style = lineStyles[i % lineStyles.length];
        return {
          name: sym,
          data: seriesData,
          lineWidth: style.lineWidth,
          dashStyle: style.dashStyle,
          color: '#000000',
          marker: { enabled: false }
        };
      });

      // X-axis label format
      var xFormat = periodDays <= 7 ? '{value:%b %e}' : (periodDays <= 90 ? '{value:%b %e}' : '{value:%b %Y}');

      // Render Highcharts
      Highcharts.chart('{{ chart_id }}', {
        chart: { type: 'line', animation: false, spacing: [10, 10, 20, 10] },
        title: { text: null },
        plotOptions: {
          series: {
            animation: false,
            enableMouseTracking: false,
            states: { hover: { enabled: false } },
            marker: { enabled: false }
          }
        },
        series: series,
        tooltip: { enabled: false },
        legend: {
          enabled: true,
          align: 'right',
          verticalAlign: 'top',
          layout: 'vertical',
          itemStyle: { fontSize: '14px', fontWeight: 'bold', color: '#000000' }
        },
        yAxis: {
          labels: {
            style: { fontSize: '18px', color: '#000000', fontWeight: 'bold' },
            x: -5,
            formatter: function() { return (this.value >= 0 ? '+' : '') + this.value.toFixed(1) + '%'; }
          },
          gridLineDashStyle: 'shortdot',
          gridLineWidth: 1,
          gridLineColor: '#000000',
          tickAmount: 5,
          title: { text: null },
          plotLines: [{
            value: 0,
            color: '#000000',
            width: 2,
            zIndex: 3
          }]
        },
        xAxis: {
          type: 'datetime',
          labels: {
            style: { fontSize: '16px', color: '#000000', fontWeight: 'bold' },
            format: xFormat
          },
          lineWidth: 1,
          lineColor: '#000000',
          tickWidth: 2,
          tickLength: 8,
          tickColor: '#000000',
          tickPixelInterval: 140,
          title: { text: null }
        },
        credits: { enabled: false }
      });
    }
  })();
</script>

<script>
  (function() {
    var view = document.querySelector('.view--half_vertical, .view--quadrant');
    if (view) {
      var grid = view.querySelector('.stats-row .grid');
      if (grid) {
        grid.style.setProperty('grid-template-columns', '1fr', 'important');
      }
    }
  })();
</script>
